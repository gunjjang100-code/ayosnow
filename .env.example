DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
APP_URL="https://your-production-domain.com"
NEXTAUTH_URL="https://your-production-domain.com"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
PAYMONGO_SECRET_KEY="replace-with-paymongo-secret"
PAYMONGO_PUBLIC_KEY="replace-with-paymongo-public"
PAYMONGO_WEBHOOK_SECRET="replace-with-paymongo-webhook-secret"
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY="replace-with-vapid-public-key"
WEB_PUSH_PRIVATE_KEY="replace-with-vapid-private-key"
WEB_PUSH_CONTACT_EMAIL="mailto:admin@your-production-domain.com"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
RESEND_API_KEY="replace-with-resend-api-key"
EMAIL_FROM="AyosNow <noreply@your-production-domain.com>"
TWILIO_ACCOUNT_SID="replace-with-twilio-account-sid"
TWILIO_AUTH_TOKEN="replace-with-twilio-auth-token"
TWILIO_FROM_NUMBER="+10000000000"

# 운영에서는 아래 두 값을 true로 두면 안 됩니다.
# 로컬 데모 검수에서만 필요할 때 켜세요.
ENABLE_DEMO_AUTH="false"
ENABLE_DEMO_DATA="false"
